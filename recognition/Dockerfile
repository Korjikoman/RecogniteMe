# Используем официальный образ Python 3.9 на основе Debian (slim — маленький размер)
FROM python:3.9-slim

# Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# Копируем файл зависимостей (если он есть) и устанавливаем их
# Это делается до копирования всего кода, чтобы использовать кэш Docker
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Копируем весь код Python-сервиса в рабочую директорию
COPY . .

# Команда по умолчанию — запуск основного скрипта (измените название на ваш)
CMD ["python", "main.py"]